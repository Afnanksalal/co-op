{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Co-Op",
  "version": "1.0.3",
  "identifier": "com.coop.desktop",
  "build": {
    "frontendDist": "../out-tauri",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run export:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Co-Op Desktop",
        "url": "desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:; font-src 'self' data:; connect-src ipc: http://localhost:* http://127.0.0.1:* https:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  }
}
