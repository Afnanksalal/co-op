# Co-Op Frontend Environment Configuration
# Copy this file to .env.local for local web development or configure these
# values in your deployment/build environment.

# Public site and OAuth callbacks
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase auth
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Co-Op cloud license backend
# API URL includes the backend API prefix.
NEXT_PUBLIC_API_URL="http://localhost:3000/api/v1"

# Cloud URL is the backend origin without /api/v1; the Tauri activation flow
# appends /api/v1/licenses/... itself.
NEXT_PUBLIC_CLOUD_URL="http://localhost:3000"
