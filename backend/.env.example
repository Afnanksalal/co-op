# Co-Op Backend Environment Configuration
# Copy this file to .env for local development.
# Configure production values in Render instead of committing secrets.

# Server
NODE_ENV="development"
PORT="3000"
API_PREFIX="api/v1"

# Database
DATABASE_URL="postgresql://user:password@host:5432/co-op?sslmode=require"
DATABASE_SSL_REJECT_UNAUTHORIZED="true"

# Supabase auth
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# License control plane
# Production must use a unique value with at least 32 characters.
LICENSE_KEY_PEPPER="change-me-to-a-secure-32-character-minimum-secret"
LICENSE_OFFLINE_GRACE_DAYS="14"

# Rate limiting
THROTTLE_TTL="60"
THROTTLE_LIMIT="100"

# Network
CORS_ORIGINS="https://co-op.software,http://localhost:3000"
APP_URL="https://api.co-op.software"

# Logging
LOG_LEVEL="debug"
