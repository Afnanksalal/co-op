{
  "name": "@co-op/backend",
  "version": "1.0.0",
  "description": "Co-Op cloud license control plane",
  "author": "Co-Op Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "ts-node -r tsconfig-paths/register src/main.ts",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:debug": "node --inspect -r ts-node/register -r tsconfig-paths/register src/main.ts",
    "start:prod": "node dist/main.js",
    "db:migrate": "node scripts/migrate.mjs",
    "licenses:backfill-users": "node scripts/backfill-supabase-users.mjs",
    "test": "node --test -r ts-node/register -r tsconfig-paths/register test/license-crypto.test.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.26",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/throttler": "^6.5.0",
    "@supabase/supabase-js": "^2.108.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "helmet": "^8.0.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
